# Supabase
VITE_SUPABASE_URL=https://<project>.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
DATABASE_URL=postgresql://postgres:[PASSWORD]@aws-0-ap-northeast-1.pooler.supabase.com:5432/postgres

# LLM + retrieval
CLAUDE_API_KEY=sk-ant-...
COHERE_API=...

# Optional model overrides (defaults are sane)
# ANTHROPIC_MODEL=claude-sonnet-4-6
# EMBEDDING_MODEL=embed-multilingual-v3.0
# RERANK_MODEL=rerank-multilingual-v3.0

# Observability (optional but recommended)
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_BASE_URL=https://jp.cloud.langfuse.com

# NotePM (v2)
# NOTEPM_API_TOKEN=
# NOTEPM_TEAM_DOMAIN=gastroduce
# NOTEPM_WEBHOOK_SECRET=

# Slack (post-rotation; v2)
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_SIGNING_SECRET=...

# MCP (Streamable HTTP server for external agents — Claude Code, Cursor, etc.)
# Comma-separated "label:token" pairs. The label appears as user_id="mcp:<label>"
# in the queries table. Mint tokens with:
#   python -c "import secrets; print('tok_' + secrets.token_urlsafe(32))"
# Leave blank to disable the /mcp route entirely.
# GASTROBRAIN_MCP_TOKENS=itsuki:tok_xxx,team-alpha:tok_yyy
# GASTROBRAIN_MCP_ENABLED=true

# Runtime
ENV=dev
LOG_LEVEL=INFO
