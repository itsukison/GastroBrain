# Supabase
VITE_SUPABASE_URL=https://<project>.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
DATABASE_URL=postgresql://postgres:[PASSWORD]@aws-0-ap-northeast-1.pooler.supabase.com:5432/postgres

# LLM + retrieval
CLAUDE_API_KEY=sk-ant-...
COHERE_API=...

# Optional model overrides (defaults are sane)
# ANTHROPIC_MODEL=claude-sonnet-4-6
# EMBEDDING_MODEL=embed-multilingual-v3.0
# RERANK_MODEL=rerank-multilingual-v3.0

# Observability (optional but recommended)
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_BASE_URL=https://jp.cloud.langfuse.com

# NotePM (v2)
# NOTEPM_API_TOKEN=
# NOTEPM_TEAM_DOMAIN=gastroduce
# NOTEPM_WEBHOOK_SECRET=

# Slack (post-rotation; v2)
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_SIGNING_SECRET=...

# MCP (Streamable HTTP server for external agents — Claude Code, Cursor, etc.)
#
# Two auth paths, both optional:
#   1. OAuth 2.1 (recommended) — browser sign-in with Google. Requires the
#      four GOOGLE_OAUTH_* / GASTROBRAIN_OAUTH_* values below.
#   2. Static bearer tokens — admin-minted env tokens AND/OR user-minted PATs
#      stored in the mcp_tokens table.
# Set GASTROBRAIN_MCP_ENABLED=false to disable /mcp/ entirely.
# GASTROBRAIN_MCP_TOKENS=itsuki:tok_xxx,team-alpha:tok_yyy
# GASTROBRAIN_MCP_ENABLED=true

# OAuth 2.1 for /mcp/. Empty values disable the OAuth surface; static tokens
# still work. Mint the two HMAC keys with:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
# GOOGLE_OAUTH_CLIENT_ID=xxxxx.apps.googleusercontent.com
# GOOGLE_OAUTH_CLIENT_SECRET=...
# GASTROBRAIN_OAUTH_JWT_KEY=...
# GASTROBRAIN_OAUTH_STATE_KEY=...
# Public-facing base URL (no trailing slash); used as issuer + audience
# GASTROBRAIN_OAUTH_ISSUER=https://gastrobrain-<hash>-an.a.run.app

# Runtime
ENV=dev
LOG_LEVEL=INFO
