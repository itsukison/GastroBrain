# Supabase — same project as the backend
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_PROJECT_URL=https://<project-ref>.supabase.co

NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key-from-supabase-dashboard-settings-api>
SUPABASE_JWT_SECRET=<jwt-secret-from-supabase-dashboard-settings-api>

# Cloud Run base URL for the FastAPI backend
GASTROBRAIN_API_URL=https://gastrobrain-<hash>-an.a.run.app

# Optional — only used for server-to-server troubleshooting
GASTROBRAIN_API_TIMEOUT_MS=120000
